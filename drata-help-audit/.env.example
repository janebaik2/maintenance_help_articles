# ─── Intercom ─────────────────────────────────────────────────────────────────
# Access Token from https://app.intercom.com/a/apps/_/settings/api-keys
INTERCOM_TOKEN=your_intercom_token_here

# ─── GitHub ───────────────────────────────────────────────────────────────────
# Fine-grained PAT with "Contents: read" and "Metadata: read" on the repo
# https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=drata
GITHUB_REPO=your_repo_name_here   # e.g. "app" or "platform" — just the repo name, not the full URL

# ─── Anthropic (Claude) ───────────────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Brave Search (optional — enables real-time third-party change detection) ──
# Free tier: 2,000 queries/month. Get key at https://brave.com/search/api/
# If omitted, the third-party audit still runs using Claude's training knowledge only.
BRAVE_SEARCH_API_KEY=
